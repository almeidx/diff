{
	"name": "diff",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "wrangler deploy",
		"dev": "vite dev",
		"fmt": "oxfmt && oxlint --fix --vitest-plugin --ignore-pattern \"**/*.svelte\"",
		"lint": "oxfmt --check && oxlint --deny-warnings --vitest-plugin --ignore-pattern \"**/*.svelte\"",
		"preview": "wrangler dev",
		"test": "vitest run",
		"test:ci": "pnpm test",
		"test:e2e": "pnpm test:smoke",
		"test:watch": "vitest",
		"test:smoke": "playwright test"
	},
	"dependencies": {
		"@zag-js/combobox": "^1.35.3",
		"@zag-js/radio-group": "^1.35.3",
		"@zag-js/svelte": "^1.35.3",
		"@zag-js/switch": "^1.35.3",
		"@zag-js/tree-view": "^1.35.3",
		"diff-match-patch": "^1.0.5",
		"fflate": "^0.8.2",
		"prismjs": "^1.30.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@types/diff-match-patch": "^1.0.36",
		"@types/node": "^25.4.0",
		"@types/prismjs": "^1.26.6",
		"oxfmt": "^0.37.0",
		"oxlint": "^1.52.0",
		"svelte": "^5.53.9",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.1",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"wrangler": "^4.71.0"
	},
	"packageManager": "pnpm@10.32.0",
	"pnpm": {
		"overrides": {
			"cookie": "^0.7.2"
		}
	}
}
