{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"tabWidth": 2,
	"useTabs": true,
	"printWidth": 120,
	"ignorePatterns": [
		".claude/**",
		".svelte-kit/**",
		".wrangler/**",
		"wrangler-local-state/**",
		"dist/**",
		"build/**",
		"coverage/**",
		"node_modules/**",
		"playwright-report/**",
		"test-results/**"
	]
}
